# Copy to .env and fill in. Never commit .env.

# --- LLM ---
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini

# --- Paths ---
PCT_DATA_DIR=./data
PCT_DB_PATH=./data/toolkit.db
PCT_AUDIT_LOG_PATH=./data/audit.log

# --- Secure defaults (override only with reason) ---
PCT_LLM_TEMPERATURE=0.3
PCT_LLM_MAX_TOKENS=2000
PCT_MAX_FILE_SIZE_MB=10
PCT_MAX_URL_FETCH_BYTES=5000000
PCT_REQUEST_TIMEOUT_S=30
PCT_CONFIDENCE_THRESHOLD=0.75

# --- MCP ---
PCT_MCP_HOST=127.0.0.1
PCT_MCP_PORT=8765

# --- MCP auth + rate limiting ---
# DO NOT put a real key in this file or in code. Generate one with:
#     python scripts/generate_api_key.py
# then export it in your shell (and optionally append to ~/.bashrc).
# The server refuses to start over HTTP if this is empty (fail securely).
PCT_MCP_API_KEY=
PCT_MCP_RATE_LIMIT_REQUESTS=60
PCT_MCP_RATE_LIMIT_WINDOW_S=60
